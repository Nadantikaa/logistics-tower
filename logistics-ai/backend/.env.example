DB_HOST=db
DB_PORT=3306
DB_USER=logistics_user
DB_PASSWORD=logistics_password
DB_NAME=logistics_db
DB_ROOT_PASSWORD=root_password

JWT_SECRET_KEY=replace-with-a-long-random-jwt-secret-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
JWT_EXPIRATION_HOURS=24

ENCRYPTION_KEY=change-this-key-32-chars-min-for-production!!!!!
PII_ENCRYPTION_KEY=replace-with-a-separate-long-random-encryption-secret

OPENWEATHER_API_KEY=your-openweather-api-key
OPENWEATHER_CITY=Chennai
OPENWEATHER_COUNTRY=IN
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
ALERT_CONFIDENCE_THRESHOLD=75

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
USE_BACKGROUND_EVALUATION=false
SHIPMENTS_CACHE_TTL_SECONDS=30
SUMMARY_CACHE_TTL_SECONDS=30
REFRESH_QUEUE_KEY=queue:monitoring_refresh

ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174
COOKIE_SECURE=false
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
ADMIN_EMAILS=admin@example.com
DATABASE_URL=./data/security.db

MFA_ENABLED=true
MFA_OTP_TTL_MINUTES=10
MFA_MAX_ATTEMPTS=5
MFA_SMTP_HOST=smtp.gmail.com
MFA_SMTP_PORT=587
MFA_SMTP_USERNAME=
MFA_SMTP_PASSWORD=
MFA_SMTP_USE_TLS=true
MFA_FROM_EMAIL=no-reply@logistics-ai.local

GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
