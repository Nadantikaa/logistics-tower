# Database Configuration
DB_HOST=db
DB_PORT=3306
DB_USER=logistics_user
DB_PASSWORD=logistics_password
DB_NAME=logistics_db
DB_ROOT_PASSWORD=root_password

# JWT Configuration
JWT_SECRET_KEY=replace-with-a-long-random-jwt-secret
JWT_EXPIRATION_HOURS=24
JWT_ALGORITHM=HS256

# Encryption Configuration
ENCRYPTION_KEY=replace-with-a-long-random-encryption-secret
PII_ENCRYPTION_KEY=replace-with-a-separate-long-random-pii-secret

# API Keys
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
OPENWEATHER_API_KEY=your-openweather-api-key
OPENWEATHER_CITY=Chennai
OPENWEATHER_COUNTRY=IN

# App Configuration
ALERT_CONFIDENCE_THRESHOLD=75
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
SESSION_TTL_HOURS=12
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
ADMIN_EMAILS=admin@example.com
GOOGLE_CLIENT_ID=your-google-client-id
DATABASE_URL=./data/security.db

# Structured Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=/app/logs/backend.log
LOG_SERVICE_NAME=logistics-ai-backend
