# ── Alert Thresholds ──────────────────────────────────────────────────────────
ALERT_CONFIDENCE_THRESHOLD=75

# ── Database URL (SQLite for auth/security) ───────────────────────────────────
DATABASE_URL=./data/security.db

# ────────────────────────────────────────────────────────────────────────────
# Event-Driven Architecture — Redis & Queue Configuration
# ────────────────────────────────────────────────────────────────────────────

# ── Redis Connection ──────────────────────────────────────────────────────────
# In Docker Compose the hostname is "redis" (the service name).
# For local dev without Docker use "localhost".
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# Leave empty if Redis has no password (default for local/dev)
REDIS_PASSWORD=

# ── Cache TTL ─────────────────────────────────────────────────────────────────
# How long the enriched shipment snapshot stays in Redis before the worker
# is expected to rebuild it (in seconds).
SNAPSHOT_CACHE_TTL=300

# How long background job results (simulations, decisions) are stored (seconds).
JOB_RESULT_TTL=3600

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
